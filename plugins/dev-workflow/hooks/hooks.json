{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/check-prerequisites.sh\"",
            "statusMessage": "dev-workflow: 前提条件チェック中..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "作業が完了しました。変更内容をレビューし、テストが全て通っているか確認してください。問題があれば修正してください。"
          }
        ]
      }
    ]
  }
}
